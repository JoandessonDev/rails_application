<% content_for(:title) { "Users" } %>
<div class="w-full h-[100vh] lg:w-[90vw] mx-auto py-10">
    <div class="w-full flex justify-between items-center mb-5">
        <h1 class="font-bold text-4xl">Users</h1>
        <button onclick="handleModal()" class=
        "bg-blue-500 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded">
            New User
        </button>
    </div>
    <div id="users" class="min-w-full divide-y divide-gray-200 space-y-5">
        <% if @users.any? %>
            <div class="grid md:grid-cols-4 gap-5">
                <% @users.each do |user|%>
                    <div class="bg-white shadow rounded-lg p-5">
                        <h2 class="text-xl font-semibold mb-2"><%= user.name %></h2>
                        <p class="text-gray-600 mb-1"><strong>Email:</strong> <%= user.email %></p>
                        <p class="text-gray-600 mb-1"><strong>CPF:</strong> <%= user.cpf %></p>
                        <p class="text-gray-600 mb-1"><strong>Role:</strong> <%= user.role %></p>
                        <p class="text-gray-600"><strong>Salary:</strong> $<%= number_to_currency(user.salary, unit: "", precision: 2) %></p>
                        <div class="flex gap-2 mt-3">
                            <button 
                            type="button" 
                            onclick='openEditModal(<%= user.to_json.html_safe %>)'
                            class="text-blue-500 hover:text-blue-700 font-medium">
                            Edit
                            </button>
                            <%= button_to "Delete", user_path(user), method: :delete, data: { confirm: "Are you sure?" }, class: "text-red-500 hover:text-red-700 font-medium" %>
                        </div>
                    </div>
                <%end%>
            </div>
        <%else%>
            <p class="text-gray-500 text-sm">No users found.</p>
        <%end%>
    </div>


    <%= render "user_modal" %>
    <%= javascript_importmap_tags %>

    <script> 

        function handleModal() {
            const modal = document.getElementById("userModal");
            modal.classList.toggle("hidden");

            const form = modal.querySelector("form");
            form.reset();
        }


        function openEditModal(user) {
        const modal = document.getElementById("userModal");
        modal.classList.remove("hidden");

        const form = modal.querySelector("form");

        // Preencher campos com os dados do usuário
        form.querySelector("input[name='user[name]']").value = user.name || "";
        form.querySelector("input[name='user[email]']").value = user.email || "";
        form.querySelector("input[name='user[cpf]']").value = user.cpf || "";
        form.querySelector("input[name='user[role]']").value = user.role || "";
        form.querySelector("input[name='user[salary]']").value = user.salary || "";

        // Alterar a ação do form para PATCH
        form.action = `/users/${user.id}`;

        // Adicionar input _method para PATCH
        if (!form.querySelector("input[name='_method']")) {
            const methodInput = document.createElement("input");
            methodInput.type = "hidden";
            methodInput.name = "_method";
            methodInput.value = "patch";
            form.appendChild(methodInput);
        }

        // Alterar texto do botão
        form.querySelector("input[type='submit']").value = "Update User";
        }

    </script>
</div>

