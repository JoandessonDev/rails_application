<% content_for :title, "Dashboard - Home" %>

<div class="space-y-8">
  <header>
    <h1 class="text-3xl font-extrabold text-gray-900 tracking-tight">
      Bem-vindo ao Painel, <span class="text-green-600">Admin!</span> 🚀
    </h1>
    <p class="mt-2 text-lg text-gray-600">
      Sua aplicação Rails rodando perfeitamente com Docker.
    </p>
  </header>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    
    <div class="group bg-white p-8 rounded-2xl shadow-sm border border-gray-100 hover:shadow-md transition-all">
      <div class="w-12 h-12 bg-green-100 rounded-lg flex items-center justify-center text-green-600 mb-4 group-hover:scale-110 transition-transform">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"></path>
        </svg>
      </div>
      <h3 class="text-xl font-bold text-gray-800">Gerenciar Usuários</h3>
      <p class="mt-2 text-gray-500 leading-relaxed">
        Controle quem acessa o sistema. Visualize perfis, crie novos acessos ou edite permissões.
      </p>
      <%= link_to users_path, class: "mt-6 inline-flex items-center text-green-600 font-semibold hover:text-green-700 transition-colors" do %>
        Acessar usuários
        <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
      <% end %>
    </div>

    <div class="group bg-white p-8 rounded-2xl shadow-sm border border-gray-100 hover:shadow-md transition-all">
      <div class="w-12 h-12 bg-blue-100 rounded-lg flex items-center justify-center text-blue-600 mb-4 group-hover:scale-110 transition-transform">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"></path>
        </svg>
      </div>
      <h3 class="text-xl font-bold text-gray-800">Gerenciar Posts</h3>
      <p class="mt-2 text-gray-500 leading-relaxed">
        Administre o conteúdo do blog ou as publicações do sistema de forma rápida.
      </p>
      <%= link_to posts_path, class: "mt-6 inline-flex items-center text-blue-600 font-semibold hover:text-blue-700 transition-colors" do %>
        Ver todos os posts
        <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
      <% end %>
    </div>

  </div>

  <div class="bg-gray-800 rounded-2xl p-6 text-white flex flex-col md:flex-row items-center justify-between">
    <div>
      <p class="text-gray-400 text-sm font-medium uppercase tracking-wider">Status do Ambiente</p>
      <h4 class="text-lg font-semibold italic text-green-400">Ambiente Docker: Ativo e Rodando</h4>
    </div>
    <div class="mt-4 md:mt-0 px-4 py-2 bg-gray-700 rounded-full text-xs font-mono">
      Rails v7.x | Ruby v3.x
    </div>
  </div>
</div>