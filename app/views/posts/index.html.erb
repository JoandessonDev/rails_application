<% content_for(:title) { "Gerenciar Posts" } %>

<div class="space-y-8">
  <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
    <div>
      <h1 class="text-3xl font-bold text-gray-900 tracking-tight">Posts</h1>
      <p class="text-gray-500 text-sm mt-1">Crie, edite e organize o conteúdo do seu sistema.</p>
    </div>
    
    <%= link_to new_post_path, class: "inline-flex items-center justify-center px-5 py-2.5 bg-green-600 hover:bg-green-700 text-white font-bold rounded-xl shadow-sm transition-all transform active:scale-95" do %>
      <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
      </svg>
      Novo Post
    <% end %>
  </div>

  <div id="posts" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
    <% if @posts.any? %>
      <% @posts.each do |post| %>
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden hover:shadow-md transition-shadow flex flex-col">
          <div class="h-32 bg-green-50 flex items-center justify-center text-green-200">
            <svg class="w-16 h-16" fill="currentColor" viewBox="0 0 24 24">
              <path d="M19 5v14H5V5h14m0-2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2z"/><path d="M14 17H7v-2h7v2zm3-4H7v-2h10v2zm0-4H7V7h10v2z"/>
            </svg>
          </div>

          <div class="p-5 flex-1 flex flex-col">
            <h2 class="text-lg font-bold text-gray-900 line-clamp-2 mb-2 leading-snug">
              <%= post.title %>
            </h2>
            
            <p class="text-gray-500 text-sm line-clamp-3 mb-4 flex-1">
              <%= strip_tags(post.content.to_s).truncate(100) %>
            </p>

            <div class="pt-4 border-t border-gray-50 flex items-center justify-between mt-auto">
              <div class="flex gap-3">
                <%= link_to "Editar", edit_post_path(post), class: "text-sm font-bold text-blue-600 hover:text-blue-800 transition-colors" %>
                
                <%= button_to post_path(post), 
                    method: :delete, 
                    form: { data: { turbo_confirm: "Tem certeza que deseja excluir este post?" } },
                    class: "text-sm font-bold text-red-500 hover:text-red-700 transition-colors" do %>
                  Excluir
                <% end %>
              </div>
              
              <%= link_to post, class: "p-2 bg-gray-50 hover:bg-green-100 rounded-lg text-gray-400 hover:text-green-600 transition-colors" do %>
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path></svg>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>
    <% else %>
      <div class="col-span-full py-20 bg-white rounded-3xl border-2 border-dashed border-gray-100 flex flex-col items-center justify-center text-center">
        <div class="w-16 h-16 bg-gray-50 rounded-full flex items-center justify-center text-gray-300 mb-4">
          <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"></path></svg>
        </div>
        <h3 class="text-gray-900 font-bold text-lg">Nenhum post ainda</h3>
        <p class="text-gray-500 max-w-xs mx-auto mt-1">Comece criando sua primeira publicação para o sistema.</p>
        <%= link_to "Criar primeiro post", new_post_path, class: "mt-6 text-green-600 font-bold hover:underline" %>
      </div>
    <% end %>
  </div>
</div>